ADMIN_TOKEN=change-me-in-production
CORS_ORIGINS=https://your-domain.com

# TURN Server (optional, for NAT traversal)
# Option A: Self-hosted TURN with HMAC auth (recommended for coturn)
# TURN_URLS=turn:your-turn-server.com:3478
# TURN_SECRET=your-secret-key

# Option B: Self-hosted TURN with static credentials
# TURN_URLS=turn:your-turn-server.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-password

# Option C: Built-in Metered.ca TURN provider
# TURN_METERED_ENABLED=true
# TURN_METERED_API=https://your-project.metered.live/api/v1/turn/credentials?apiKey=your-api-key
