# ── Required ───────────────────────────────────────────────
ADMIN_TOKEN=change-me-in-production
CORS_ORIGINS=https://your-domain.com

# ── TURN (optional but recommended for production) ─────────
# Mode A — Self-hosted TURN with HMAC auth (coturn use-auth-secret)
# TURN_URLS=turn:your-turn-server.com:3478
# TURN_SECRET=generated-with-openssl-rand-hex-32

# Mode B — Self-hosted TURN with static credentials
# TURN_URLS=turn:your-turn-server.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-password

# Mode C — Built-in Metered.ca TURN provider
# TURN_METERED_ENABLED=true
# TURN_METERED_API_KEY=your-metered-api-key   # Metered dashboard → "API Key"
# TURN_METERED_DOMAIN=your-app.metered.live   # Metered dashboard → subdomain
# TURN_METERED_TTL=7200                        # seconds; must match dashboard TURN_TIME
