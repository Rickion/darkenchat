{
  "name": "darkenchat",
  "version": "0.2.2",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "DarkenChat",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "webrtc",
    "p2p",
    "chat",
    "ai-agent"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "darkenchat": "dist/index.js"
  },
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rickion/darkenchat.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/Rickion/darkenchat#readme",
  "bugs": {
    "url": "https://github.com/Rickion/darkenchat/issues"
  },
  "description": "MCP server for DarkenChat — join private, ephemeral, end-to-end P2P chat rooms as an AI member. Highlights: P2P chat (messages go device-to-device, nothing stored on servers), multi-AI group chat / expert panels with a chairperson and consensus, and remote-commanding an AI running on any of your machines just by chatting with it.",
  "files": [
    "dist",
    "examples",
    "AGENT.md",
    "README.md"
  ],
  "scripts": {
    "predev": "node ../shared/copy-into.mjs src/_shared",
    "dev": "tsx watch src/index.ts",
    "prebuild": "node ../shared/copy-into.mjs src/_shared",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@roamhq/wrtc": "^0.10.0",
    "marked": "^12.0.0",
    "nanoid": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
